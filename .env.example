# 🌌 TON-618 v2 — Configuração via Environment Variables
# Copie este arquivo para .env e preencha os valores

# --- Provedor de Embeddings ---
# Opções: gemini (padrão, grátis), ollama (local), openai
EMBEDDING_PROVIDER=gemini

# API Key (obrigatório para Gemini e OpenAI)
# Gemini: https://aistudio.google.com/apikey
# OpenAI: https://platform.openai.com/api-keys
EMBEDDING_API_KEY=AIzaS...

# Modelo de embedding (padrão: text-embedding-004 para Gemini)
EMBEDDING_MODEL=text-embedding-004

# Dimensão do embedding (padrão: 768)
EMBEDDING_DIM=768

# Embed todas as notas automaticamente (true/false)
EMBEDDING_ALL=false

# --- Servidor Ollama (apenas se EMBEDDING_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# --- Diretórios ---
DOCS_DIR=./docs
DB_PATH=./data/ton618.db
STATE_DIR=./data

# --- Servidor ---
PORT=6180

# --- Autenticação Básica ---
AUTH_USER=admin
AUTH_PASS=ton618

# --- Polling (segundos entre verificações) ---
POLL_INTERVAL_SEC=30

EMBEDDING_MODEL=gemini-embedding-2


# 🌌 TON-618 v2 — Configuração via Environment Variables
# Copie este arquivo para .env e preencha os valores

# --- Provedor de Embeddings ---
# Opções: gemini (padrão, grátis), ollama (local), openai
EMBEDDING_PROVIDER=gemini

# API Key (obrigatório para Gemini e OpenAI)
# Gemini: https://aistudio.google.com/apikey
# OpenAI: https://platform.openai.com/api-keys
EMBEDDING_API_KEY=AIzaSyBGjjDCfNQ6kjq_3mxJp7hY5lCUCRAPT5g

# Dimensão do embedding (padrão: 768)
EMBEDDING_DIM=768

# Embed todas as notas automaticamente (true/false)
EMBEDDING_ALL=false

# --- Diretórios ---
DOCS_DIR=./docs
DB_PATH=./data/ton618.db
STATE_DIR=./data

# --- Servidor ---
PORT=6180

# --- Autenticação Básica ---
AUTH_USER=admin
AUTH_PASS=ton618
# --- Polling (segundos entre verificações) ---
POLL_INTERVAL_SEC=30
